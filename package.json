{
  "name": "controle-financeiro-monolith",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter financeapp-api dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter financeapp-api dev:dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter financeapp-api build && pnpm --filter web build",
    "build:api": "pnpm --filter financeapp-api build",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm --filter financeapp-api type-check && pnpm --filter web lint",
    "lint:api": "pnpm --filter financeapp-api type-check",
    "lint:web": "pnpm --filter web lint",
    "test": "pnpm --filter web test",
    "docker:up": "docker-compose up -d",
    "docker:up:build": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:api": "docker-compose logs -f api",
    "docker:logs:web": "docker-compose logs -f web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
