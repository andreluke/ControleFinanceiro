{
	"name": "financeapp-api",
	"version": "1.0.0",
	"description": "FinanceApp API - Controle Financeiro Pessoal",
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file .env.dev src/index.ts",
		"build": "tsup src/index.ts --format cjs --dts",
		"build:production": "echo === MIGRATIONS === && drizzle-kit migrate && echo '' && echo === BUILD === && tsup src/index.ts --format cjs --dts",
		"start": "node dist/index.cjs",
		"drizzle:generate": "drizzle-kit generate",
		"drizzle:migrate": "drizzle-kit migrate",
		"drizzle:migrate:test": "cross-env DATABASE_URL=postgres://test:test@localhost:5433/financeapp_test drizzle-kit migrate",
		"drizzle:studio": "drizzle-kit studio",
		"lint": "biome check src",
		"format": "biome format --write src",
		"type-check": "tsc --noEmit",
		"test": "vitest --verbose",
		"test:ci": "cross-env DATABASE_URL=postgres://test:test@localhost:5433/financeapp_test vitest run",
		"docker:test:up": "docker compose -f docker-compose.test.yml up -d",
		"docker:test:down": "docker compose -f docker-compose.test.yml down",
		"test:all": "pnpm docker:test:up && npx wait-on tcp:5433 && pnpm drizzle:migrate:test && pnpm test:ci && pnpm docker:test:down"
	},
	"dependencies": {
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^10.0.1",
		"@fastify/jwt": "^9.0.1",
		"@fastify/swagger": "^9.4.0",
		"@fastify/swagger-ui": "^5.2.5",
		"bcryptjs": "^3.0.3",
		"chart.js": "^4.5.1",
		"chartjs-node-canvas": "^5.0.0",
		"drizzle-orm": "^0.36.0",
		"exceljs": "^4.4.0",
		"fastify": "^5.1.0",
		"pdfkit": "^0.12.3",
		"postgres": "^3.4.5",
		"resend": "^6.9.4",
		"serve": "^14.2.6",
		"xlsx": "^0.18.5",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@react-email/components": "^1.0.10",
		"@types/bcryptjs": "^3.0.0",
		"@types/node": "^22.10.0",
		"@types/pdfkit": "^0.17.5",
		"@types/react": "^19.2.14",
		"@vitest/coverage-v8": "^4.0.18",
		"cross-env": "^10.1.0",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.28.0",
		"pino-pretty": "^13.1.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tsup": "^8.3.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18",
		"wait-on": "^9.0.4"
	}
}
